-- Auto-capitalize for inputs
wearNameInput:GetPropertyChangedSignal("Text"):Connect(function()
    local cursor = wearNameInput.CursorPosition
    local inputText = wearNameInput.Text
    local newText = autoCapitalize(inputText)
    if newText ~= inputText then
        wearNameInput.Text = newText
        wearNameInput.CursorPosition = math.max(1, math.min(cursor + (#newText - #inputText), #newText + 1))
    end
end)

