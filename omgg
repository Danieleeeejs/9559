-- Equip All Wears (with progress)
equipAllWearsButton.MouseButton1Click:Connect(function()
    stopEquipping = false
    
    -- Show progress UI
    progressFrame.Visible = true
    progressText.Visible = true
    progressBar.Size = UDim2.new(0, 0, 1, 0)
    
    statusLabel.Text = "⏳ Equipping all wears..."
    statusLabel.TextColor3 = Color3.fromRGB(255, 200, 100)
    
    local wears = GetAllPetWears()
    local total = #wears
    local equipped = 0
    local failed = 0
    
    for i, wear in ipairs(wears) do
        if stopEquipping then
            statusLabel.Text = "⏹️ Stopped at " .. i .. "/" .. total .. " wears"
            statusLabel.TextColor3 = Color3.fromRGB(255, 200, 100)
            progressText.Text = "Stopped at " .. i .. "/" .. total
            break
        end
        
        -- Update progress
        local progress = i / total
        progressBar.Size = UDim2.new(progress, 0, 1, 0)
        progressText.Text = "Equipping: " .. wear.name .. " (" .. i .. "/" .. total .. ")"
        
        if EquipWearOnPet(wear.id) then
            equipped = equipped + 1
        else
            failed = failed + 1
        end
        task.wait(0.05)
    end
    
    if not stopEquipping then
        statusLabel.Text = "✅ Equipped: " .. equipped .. ", ❌ Failed: " .. failed
        statusLabel.TextColor3 = equipped > 0 and Color3.fromRGB(100, 255, 100) or Color3.fromRGB(255, 100, 100)
        progressText.Text = "Complete! " .. equipped .. "/" .. total
    end
    
    -- Hide progress after 3 seconds
    task.delay(3, function()
        if not stopEquipping then
            progressFrame.Visible = false
            progressText.Visible = false
        end
    end)
end)

