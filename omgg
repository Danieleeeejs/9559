local function GetPetWearByName(name)
    for id, v in pairs(InventoryDB.pet_accessories or {}) do
        if v.name and v.name:lower() == name:lower() then
            return id
        end
    end
    return false
end

local function GetAllPetWears()
    local wears = {}
    for id, v in pairs(InventoryDB.pet_accessories or {}) do
        if v.name and v.name ~= "" then
            table.insert(wears, {id = id, name = v.name})
        end
    end
    return wears
end

local function GetPreppyWears()
    local wears = {}
    for _, wearName in ipairs(PreppyWears) do
        local id = GetPetWearByName(wearName)
        if id then
            table.insert(wears, {id = id, name = wearName})
        end
    end
    return wears
end

local function EquipWearOnPet(wearId)
    if not PetAccessoryEquipHelper then
        warn("[PetWear] PetAccessoryEquipHelper not loaded")
        return false
    end
    
    local wearEntry = InventoryDB.pet_accessories and InventoryDB.pet_accessories[wearId]
    if not wearEntry then
        warn("[PetWear] No entry in InventoryDB.pet_accessories for: " .. tostring(wearId))
        return false
    end
    
    local wrappers = ClientData.get("pet_char_wrappers")
    if not wrappers or #wrappers == 0 then
        warn("[PetWear] No pet equipped")
        return false
    end
    
    local petModel = wrappers[#wrappers].char
    if not petModel or not petModel:IsDescendantOf(workspace) then
        warn("[PetWear] Could not find pet model in workspace")
        return false
    end
    
    task.spawn(function()
        local ok, accessoryAsset = pcall(function()
            return DownloadClient.promise_download_copy("PetAvatarResources", wearEntry.model_handle):expect()
        end)
        if not ok or not accessoryAsset then
            warn("[PetWear] Failed to download asset for: " .. tostring(wearEntry.model_handle))
            return
        end
        
        local success, result = pcall(function()
            return PetAccessoryEquipHelper.equip_accessory({
                pet_model = petModel,
                accessory_base_asset = accessoryAsset,
                accessory_item_entry = wearEntry,
                play_poof_effect = true,
                is_mannequin = false,
            })
        end)
        
        if success and result then
            print("[PetWear] Equipped: " .. (wearEntry.name or wearId))
        else
            warn("[PetWear] equip_accessory failed: " .. tostring(result))
        end
    end)
    return true
end

local function EquipAllPetWears()
    local wears = GetAllPetWears()
    local equipped = 0
    local failed = 0
    
    for i, wear in ipairs(wears) do
        if stopEquipping then
            print("[PetWear] Stopped at wear " .. i .. "/" .. #wears)
            break
        end
        if EquipWearOnPet(wear.id) then
            equipped = equipped + 1
        else
            failed = failed + 1
        end
        task.wait(0.05)
    end
    
    return equipped, failed
end

